# ─────────────────────────────────────────────────────────────
#  04 - DELETE Requests
#  DELETE removes a resource.
#  A successful delete returns 200 OK with an empty body {}.
#  Some APIs return 204 No Content (no body at all).
# ─────────────────────────────────────────────────────────────

@baseUrl = https://jsonplaceholder.typicode.com

# ── Delete a post ─────────────────────────────────────────────

### Delete Post 1
DELETE {{baseUrl}}/posts/1


# ── Delete a user ─────────────────────────────────────────────

### Delete User 1
DELETE {{baseUrl}}/users/1


# ── Delete a todo ─────────────────────────────────────────────

### Delete Todo 1
DELETE {{baseUrl}}/todos/1


# ─────────────────────────────────────────────────────────────
#  Common DELETE response codes:
#
#  200 OK          — deleted, returns empty body or confirmation
#  204 No Content  — deleted, no response body
#  404 Not Found   — resource didn't exist
# ─────────────────────────────────────────────────────────────
