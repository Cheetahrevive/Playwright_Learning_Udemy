{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug all tests — opens Playwright Inspector on each action
      "name": "Debug: All Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--debug"],
      "cwd": "${workspaceFolder}",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal"
    },
    {
      // Debug the file currently open in the editor
      "name": "Debug: Current File",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "${relativeFile}", "--debug"],
      "cwd": "${workspaceFolder}",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal"
    },
    {
      // Debug Chromium only
      "name": "Debug: Chromium",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--project=chromium", "--debug"],
      "cwd": "${workspaceFolder}",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal"
    },
    {
      // Debug Firefox only
      "name": "Debug: Firefox",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--project=firefox", "--debug"],
      "cwd": "${workspaceFolder}",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal"
    },
    {
      // Debug WebKit only
      "name": "Debug: WebKit",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--project=webkit", "--debug"],
      "cwd": "${workspaceFolder}",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal"
    }
  ]
}
